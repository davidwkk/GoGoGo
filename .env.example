# =============================================================================
# gogogo — Environment Variables Template
# Copy this file to .env and fill in your API keys
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://gogogo:gogogo@db:5432/gogogo

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=43200 # 30 days for demo

# -----------------------------------------------------------------------------
# Google AI (Gemini)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your-google-ai-studio-api-key
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_LITE_MODEL=gemini-3.1-flash-lite-preview
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# -----------------------------------------------------------------------------
# SerpAPI (Web Search, Flights, Hotels)
# -----------------------------------------------------------------------------
SERPAPI_KEY=your-serpapi-api-key

# -----------------------------------------------------------------------------
# OpenWeatherMap
# -----------------------------------------------------------------------------
OPENWEATHER_API_KEY=your-openweathermap-api-key

# -----------------------------------------------------------------------------
# Google Maps (Static/Embed API)
# -----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=DEBUG
