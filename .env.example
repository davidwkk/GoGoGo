# =============================================================================
# gogogo — Environment Variables Template
# Copy this file to .env and fill in your API keys
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://gogogo:gogogo@db:5432/gogogo

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=43200 # 30 days for demo

# -----------------------------------------------------------------------------
# Google AI (Gemini)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your-google-ai-studio-api-key
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_LITE_MODEL=gemini-3.1-flash-lite-preview
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview

# -----------------------------------------------------------------------------
# SerpAPI (Flights, Hotels) - fallback search
# -----------------------------------------------------------------------------
SERPAPI_KEY=your-serpapi-api-key

# -----------------------------------------------------------------------------
# Tavily AI (Web Search - primary)
# -----------------------------------------------------------------------------
TAVILY_API_KEY=your-tavily-api-key

# -----------------------------------------------------------------------------
# OpenWeatherMap
# -----------------------------------------------------------------------------
OPENWEATHER_API_KEY=your-openweathermap-api-key

# -----------------------------------------------------------------------------
# Google Maps (Static/Embed API)
# -----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=DEBUG

# -----------------------------------------------------------------------------
# VPN Proxy (Optional - for routing LLM calls through NordVPN)
# Uses OpenVPN tunnel to NordVPN Singapore/Japan server
# -----------------------------------------------------------------------------
# NordVPN Service Credentials (from dashboard.nordvpn.com → Account → Manual setup → Service credentials)
OVPN_USERNAME=
OVPN_PASSWORD=

# OpenVPN Server (from downloaded .ovpn config, e.g., sg475.nordvpn.com)
OVPN_SERVER=sg475.nordvpn.com
OVPN_PROTO=udp

# Enable SOCKS5 proxy for LLM calls (set to true to enable)
LLM_PROXY_ENABLED=false

# SOCKS5 proxy URL (vpn-proxy runs on host.docker.internal:1080)
SOCKS5_PROXY_URL=socks5://host.docker.internal:1080
